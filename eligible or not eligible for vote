import java.util.*;

public class Main {

    public static boolean isEligible(int age){
        return age >= 18;
    }

    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);

        int age = sc.nextInt();

        if(isEligible(age)){
            System.out.println("Eligible");
        } else {
            System.out.println("Not eligible");
        }
    }
}
