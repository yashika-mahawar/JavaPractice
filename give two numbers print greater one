import java.util.*;

public class Main {
    public static int returnGreater(int a,int b){
        if(a>b){
            return a;
        }
        return b;
    }
    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);
        
        int a= sc.nextInt();
        int b = sc.nextInt();
        
        int result = returnGreater(a, b);
        System.out.println(result);
    }
}
