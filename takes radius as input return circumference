import java.util.*;

public class Main {
    public static double printCircumference(int r){
        return 2*3.14*r;
    }
    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);
        
        int r= sc.nextInt();

        
        double result = printCircumference(r);
        System.out.println(result);
    }
}
