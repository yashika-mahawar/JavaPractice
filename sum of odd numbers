import java.util.*;

public class Main {
    public static int sumOfOddNumbers(int n, Scanner sc) {
        int sum = 0;

        for(int i = 1; i <= n; i++) {
            int num = sc.nextInt();
            
            if(num % 2 != 0) {
                sum = sum + num;
            }
        }

        return sum;
    }

    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);
        
        int n = sc.nextInt();
        
        int result = sumOfOddNumbers(n, sc);
        System.out.println("Sum is: " + result);
    }
}
